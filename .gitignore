# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Turbo / tool caches
.turbo/
.eslintcache

# Test outputs
coverage/
playwright-report/
test-results/
.vitest-cache/
# Playwright storage state — generated by auth.setup.ts, contains a
# dev cookie with tenant_id + user_id. Never committed.
apps/console/test/e2e/.auth/

# Environment — never commit real secrets
.env
.env.local
.env.*.local

# IDE / OS noise
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json.example
!.vscode/extensions.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
*.pid
*.seed

# Terraform — lockfile is committed, state + actual tfvars are not.
infra/terraform/.terraform/
infra/terraform/*/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/*/*.tfstate
infra/terraform/*/*.tfstate.backup
infra/terraform/prod.tfvars
infra/terraform/*.auto.tfvars
infra/terraform/crash.log
