# Environment variables consumed by the ERP platform.
#
# Copy this file to `.env` (gitignored) and adjust for your machine.
# Defaults assume the compose.dev.yml stack is running on localhost with
# the ports this file declares.
#
# Rule: never commit a real secret. If a value belongs in `.env` but not
# `.env.example`, document the variable here without the value.

# ──────────────────────────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────────
# PostgreSQL (compose.dev.yml: service `postgres`)
# ──────────────────────────────────────────────────────────────────
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp
POSTGRES_DB=erp_dev
POSTGRES_PORT=5432

# Connection string consumed by Kysely/pg.
DATABASE_URL=postgresql://erp:erp@localhost:5432/erp_dev

# ──────────────────────────────────────────────────────────────────
# Redis (compose.dev.yml: service `redis`)
# ──────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────
# OpenSearch (compose.dev.yml: service `opensearch`)
# ──────────────────────────────────────────────────────────────────
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://localhost:9200
# Heap size for the OpenSearch JVM. Defaults suit a laptop; raise if
# you import large index fixtures.
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# ──────────────────────────────────────────────────────────────────
# OpenTelemetry → Grafana Cloud (TASK-14.3)
# ──────────────────────────────────────────────────────────────────
# When both are set, every service installs the OTLP/HTTP exporter
# and ships traces + metrics to Grafana Cloud. When unset (the dev
# default), @opentelemetry/api returns the NoOp tracer — every
# createTracer() call still works, nothing leaves the process.
#
# Endpoint: Grafana Cloud's OTLP gateway base URL. Signal paths
# (/v1/traces, /v1/metrics) are appended automatically, so set the
# base only. Example:
#   https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
# GRAFANA_CLOUD_OTLP_ENDPOINT=
#
# Headers: OTEL-spec comma-separated key=value pairs with URL-encoded
# values. The one that matters is authorization — Grafana Cloud gives
# you an instance ID + API token; base64-encode them as `id:token` and
# prepend "Basic ". Example:
#   GRAFANA_CLOUD_OTLP_HEADERS=authorization=Basic%20MTIzOmFiY2RlZg==
# GRAFANA_CLOUD_OTLP_HEADERS=

# ──────────────────────────────────────────────────────────────────
# Future variables (documented here before the code that reads them):
#   BETTER_AUTH_SECRET            — TASK-10.1b.1 (session signing)
#   BETTER_AUTH_URL               — TASK-10.1b.1
# ──────────────────────────────────────────────────────────────────
