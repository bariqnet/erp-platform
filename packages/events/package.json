{
  "name": "@erp/events",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "EventBus port and the in-process adapter backed by a Postgres outbox.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist .turbo",
    "dev": "tsc -b --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@erp/core": "workspace:*",
    "@erp/db": "workspace:*",
    "kysely": "catalog:"
  },
  "devDependencies": {
    "@erp/config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "8.11.10",
    "pg": "8.13.3",
    "testcontainers": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
