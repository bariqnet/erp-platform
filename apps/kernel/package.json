{
  "name": "@erp/kernel",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Application Kernel service — resolves metadata, owns the L2 Redis cache.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist .turbo",
    "dev": "tsc -b --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "7.3.0",
    "@erp/core": "workspace:*",
    "@erp/db": "workspace:*",
    "@erp/events": "workspace:*",
    "@erp/kernel-runtime": "workspace:*",
    "@erp/metadata": "workspace:*",
    "@erp/telemetry": "workspace:*",
    "fastify": "4.29.0",
    "fastify-plugin": "5.0.1",
    "ioredis": "catalog:",
    "kysely": "catalog:",
    "pino": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@erp/config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "8.11.10",
    "pg": "8.13.3",
    "testcontainers": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
