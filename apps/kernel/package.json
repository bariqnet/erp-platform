{
  "name": "@erp/kernel",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Application Kernel service — resolves metadata, owns the L2 Redis cache.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
